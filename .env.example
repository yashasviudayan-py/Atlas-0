# Copy this file to .env before running the Docker Compose stack.
# Use a long random value before exposing ATLAS-0 beyond your machine.
ATLAS_API_ACCESS_TOKEN=change-me-before-hosting

# Keep broad job listing private by default. Set true only for trusted operators.
ATLAS_API_ENABLE_JOB_LISTING=false

# Public demo mode: open the visitor-facing upload/report endpoints to anonymous
# hosted requests so anyone can run their own scan. Operator tools stay private.
# A configured ATLAS_API_ACCESS_TOKEN (above) always wins and disables demo mode,
# so clear the token when you want an open public demo.
ATLAS_API_PUBLIC_DEMO=false

# Set true in hosted environments after storage and provider settings are final.
ATLAS_UPLOADS_STRICT_STARTUP_CHECKS=false
