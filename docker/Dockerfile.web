# Atlas-0 — slim, single-container web image for hosting the demo site.
#
# Unlike docker/Dockerfile (which compiles the Rust SLAM crates for the full
# stack), this image is Python-only: FastAPI + the static frontend + the
# in-process upload worker. It needs no Rust toolchain and no Ollama — when no
# VLM provider is reachable the pipeline falls back to heuristic analysis, so
# the landing page and the built-in sample Safety Brief work with zero config.
#
# This image enables public demo mode (ATLAS_API_PUBLIC_DEMO=true) so anonymous
# visitors can upload their own room photo/video and run a scan. Operator tools
# (job listing, deletion, evaluation) stay private. To lock the instance down to a
# private beta instead, set ATLAS_API_ACCESS_TOKEN — a token always wins over demo
# mode. Visitor uploads are rate-limited; see configs/default.toml [api].
#
# Build:  docker build -f docker/Dockerfile.web -t atlas0-web .
# Run:    docker run -p 8420:8420 atlas0-web
# Open:   http://localhost:8420/  (redirects to /app/)

FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/python \
    ATLAS_CONFIG=/app/configs/default.toml \
    ATLAS_API_HOST=0.0.0.0 \
    ATLAS_API_PORT=8420 \
    ATLAS_API_PUBLIC_DEMO=true \
    ATLAS_UPLOADS_WORKER_MODE=in_process \
    ATLAS_UPLOADS_STORAGE_DIR=/data/uploads

WORKDIR /app

# libgl1/libglib2.0-0 satisfy native deps used by image/video processing.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps first for better layer caching. The `video` extra adds
# walkthrough (MP4/MOV/WEBM) ingestion via PyAV (ffmpeg ships in the wheel).
COPY pyproject.toml .
COPY python/ python/
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e ".[video]"

# Runtime assets used by the API, sample report, and static app. Only the two
# data subdirs the web API actually reads are copied — the sample walkthrough
# frames and the eval corpus. The full data/ tree also holds a ~350 MB RGBD SLAM
# benchmark used only by the Rust stack, which has no place in this Python image.
COPY configs/ configs/
COPY data/sample_walkthrough/ data/sample_walkthrough/
COPY data/eval_corpus/ data/eval_corpus/
COPY frontend/ frontend/

RUN useradd --create-home --uid 10001 atlas \
    && mkdir -p /data/uploads /data/objects \
    && chown -R atlas:atlas /app /data

USER atlas

EXPOSE 8420
VOLUME ["/data"]

# Liveness probe: GET /health must return 200. Resolve the port the same way the
# CMD does ($PORT on Render/Railway/Fly, else 8420) so the probe never targets the
# wrong port when the platform injects $PORT.
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import os,urllib.request; urllib.request.urlopen('http://localhost:%s/health' % os.environ.get('PORT','8420'))"

# Respect the platform-provided $PORT (Render/Railway/Fly) and fall back to 8420.
CMD ["sh", "-c", "uvicorn atlas.api.server:app --host 0.0.0.0 --port ${PORT:-8420}"]
